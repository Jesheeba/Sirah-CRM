# Copy this file to .env.local and fill in your Supabase project values.
# Find them in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (SERVER ONLY — never prefix with NEXT_PUBLIC_, never expose to the browser).
# Required for per-tenant integration secrets: server actions read/write the secret columns
# of `integration_settings` through this key, which bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------------
# Optional GLOBAL messaging fallbacks. Per-tenant credentials configured in-app under
# Settings -> Integrations take precedence; these are used only when a tenant has not
# configured its own. Leave blank to fall back to mailto:/wa.me link mode.
# ---------------------------------------------------------------------------------
# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=
NEXT_PUBLIC_APP_URL=

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# App-level webhook verification token (stays global — one Meta app serves all numbers).
WHATSAPP_VERIFY_TOKEN=

# ---------------------------------------------------------------------------------
# Meta (Facebook/Instagram) Lead Ads — one Meta app serves ALL tenants. App ID/Secret
# are global; each tenant connects its own Page(s) via OAuth (tokens stored per tenant).
# OAuth redirect + webhook callback derive from NEXT_PUBLIC_APP_URL above:
#   redirect URI : ${NEXT_PUBLIC_APP_URL}/api/meta/oauth/callback
#   webhook URL  : ${NEXT_PUBLIC_APP_URL}/api/meta/leadgen
# ---------------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
# Any random string; echoed back during the webhook verification handshake.
META_VERIFY_TOKEN=

# ---------------------------------------------------------------------------------
# WhatsApp Embedded Signup — "Sirah CRM Wp" Meta app (separate from the Lead Ads app)
# App ID and Config ID are public (NEXT_PUBLIC_); App Secret is server-only.
#   App ID     : App Settings -> Basic -> App ID
#   Config ID  : Facebook Login for Business -> Configurations -> (your config) -> ID
#   App Secret : App Settings -> Basic -> App Secret (click Show)
# ---------------------------------------------------------------------------------
NEXT_PUBLIC_FB_APP_ID=
NEXT_PUBLIC_FB_CONFIG_ID=
FB_APP_SECRET=
